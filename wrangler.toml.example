name = "hubitat-dashboard"
main = "src/index.ts"
compatibility_date = "2025-01-01"
compatibility_flags = ["nodejs_compat"]
account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"

# Static asset serving
[assets]
directory = "./src/assets"
binding = "ASSETS"
not_found_handling = "single-page-application"

# KV namespace for config storage
# Run `wrangler kv namespace create CONFIG` to create your own and paste the IDs below
[[kv_namespaces]]
binding = "CONFIG"
id = "YOUR_KV_NAMESPACE_ID"
preview_id = "YOUR_KV_PREVIEW_NAMESPACE_ID"

# Runtime variables
[vars]
# Set to "true" only if you want multiple hubs to share this Worker.
# Requires Cloudflare Access in front of the Worker — without it, any
# caller can read/write any hub's config. Leave "false" for personal use.
MULTI_HUB = "false"

# CF Access service token for Worker → Hubitat tunnel authentication.
# Only needed if your Cloudflare Tunnel is protected by CF Access.
# Create in Zero Trust → Access → Service Auth → Service Tokens.
# Add as secrets (NOT plaintext vars) via:
#   wrangler secret put CF_ACCESS_CLIENT_ID
#   wrangler secret put CF_ACCESS_CLIENT_SECRET
# Then add the service token as an Allow policy on your tunnel's CF Access app.

# Observability
[observability]
enabled = true

# Optional: smart placement to put the worker close to your hub
# [placement]
# mode = "smart"

# Optional: custom domain — uncomment and configure
# [[routes]]
# pattern = "dashboard.example.com/*"
# zone_name = "example.com"
